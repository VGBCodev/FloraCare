rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'createdAt']) &&
             data.keys().size() <= 12 &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.createdAt is timestamp;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'content', 'createdAt', 'likesCount', 'commentsCount']) &&
             data.keys().size() <= 11 &&
             data.authorId is string &&
             data.content is string &&
             data.createdAt is timestamp &&
             data.likesCount is number &&
             data.commentsCount is number;
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'creatorId', 'createdAt', 'membersCount']) &&
             data.keys().size() <= 7 &&
             data.creatorId is string &&
             data.name is string &&
             data.createdAt is timestamp &&
             data.membersCount is number;
    }

    function isValidLike(data) {
      return data.keys().hasAll(['userId', 'createdAt']) &&
             data.keys().size() <= 3 &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['postId', 'authorId', 'authorName', 'authorPhoto', 'content', 'createdAt']) &&
             data.keys().size() <= 7 &&
             data.authorId == request.auth.uid &&
             data.content is string &&
             data.createdAt is timestamp;
    }

    function isValidMember(data) {
      return data.keys().hasAll(['userId', 'joinedAt']) &&
             data.keys().size() == 2 &&
             data.userId == request.auth.uid &&
             data.joinedAt is timestamp;
    }

    function isValidUserPlant(data) {
      return data.keys().hasAll(['ownerId', 'commonName', 'addedAt']) &&
             data.keys().size() <= 7 &&
             data.ownerId == request.auth.uid &&
             data.addedAt is timestamp;
    }

    function isValidReminder(data) {
      return data.keys().hasAll(['userId', 'plantId', 'plantName', 'type', 'frequencyDays', 'lastDone', 'nextDue', 'createdAt']) &&
             data.keys().size() <= 9 &&
             data.userId == request.auth.uid &&
             data.plantId is string &&
             data.plantName is string &&
             data.type is string &&
             data.frequencyDays is number &&
             data.lastDone is number &&
             data.nextDue is number &&
             data.createdAt is number;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['recipientId', 'senderId', 'senderName', 'type', 'isRead', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.recipientId is string &&
             data.senderId == request.auth.uid &&
             data.senderName is string &&
             data.type in ['like', 'comment', 'new_post'] &&
             data.isRead == false &&
             data.createdAt is timestamp;
    }

    // --- Matches ---
    
    // Collection Group Queries
    match /{path=**}/likes/{id} {
      allow read: if isSignedIn() && (id == request.auth.uid || (resource != null && resource.data.userId == request.auth.uid));
    }
    match /{path=**}/members/{id} {
      allow read: if isSignedIn() && (id == request.auth.uid || (resource != null && resource.data.userId == request.auth.uid));
    }
    
    match /test/connection {
      allow get: if true;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      incoming().uid == existing().uid &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'updatedAt']);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                      isValidId(postId) && 
                      isValidPost(incoming()) &&
                      incoming().authorId == request.auth.uid &&
                      incoming().likesCount == 0 &&
                      incoming().commentsCount == 0;
      allow update: if isSignedIn() && (
        // Action: Edit (Owner only)
        (isOwner(existing().authorId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['content', 'imageUrl', 'plantType']) &&
         incoming().authorId == existing().authorId &&
         incoming().createdAt == existing().createdAt) ||
        // Action: Like (Anyone signed in, atomic)
        (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) && (
          (incoming().likesCount == existing().likesCount + 1 && existsAfter(/databases/$(database)/documents/posts/$(postId)/likes/$(request.auth.uid))) ||
          (incoming().likesCount == existing().likesCount - 1 && !existsAfter(/databases/$(database)/documents/posts/$(postId)/likes/$(request.auth.uid)))
        )) ||
        // Action: Comment (Anyone signed in, atomic)
        (incoming().diff(existing()).affectedKeys().hasOnly(['commentsCount']) && 
         incoming().commentsCount == existing().commentsCount + 1)
      );
      allow delete: if isSignedIn() && isOwner(existing().authorId);

      match /likes/{userId} {
        allow read: if true;
        allow create: if isOwner(userId) && isValidLike(incoming()) && 
                        getAfter(/databases/$(database)/documents/posts/$(postId)).data.likesCount == 
                        get(/databases/$(database)/documents/posts/$(postId)).data.likesCount + 1;
        allow delete: if isOwner(userId) && 
                        getAfter(/databases/$(database)/documents/posts/$(postId)).data.likesCount == 
                        get(/databases/$(database)/documents/posts/$(postId)).data.likesCount - 1;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidComment(incoming()) && 
                        getAfter(/databases/$(database)/documents/posts/$(postId)).data.commentsCount == 
                        get(/databases/$(database)/documents/posts/$(postId)).data.commentsCount + 1;
        allow delete: if isOwner(existing().authorId) || isOwner(resource.data.authorId);
      }
    }

    match /users/{userId}/plants/{plantId} {
      allow read, write: if isOwner(userId);
    }

    match /reminders/{reminderId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidReminder(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['lastDone', 'nextDue']) &&
                      incoming().lastDone is number &&
                      incoming().nextDue is number;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
    
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
    }

    match /groups/{groupId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                      isValidGroup(incoming()) &&
                      incoming().creatorId == request.auth.uid &&
                      incoming().membersCount == 1;
      allow update: if isSignedIn() && (
        (isOwner(existing().creatorId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'imageUrl', 'updatedAt']) &&
         incoming().creatorId == existing().creatorId &&
         incoming().createdAt == existing().createdAt) ||
        // Action: Join/Leave Group (Atomic)
        (incoming().diff(existing()).affectedKeys().hasOnly(['membersCount']) && (
          (incoming().membersCount == existing().membersCount + 1 && existsAfter(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid))) ||
          (incoming().membersCount == existing().membersCount - 1 && !existsAfter(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)))
        ))
      );

      match /members/{userId} {
        allow read: if true;
        allow create: if isOwner(userId) && isValidMember(incoming()) &&
                        getAfter(/databases/$(database)/documents/groups/$(groupId)).data.membersCount == 
                        get(/databases/$(database)/documents/groups/$(groupId)).data.membersCount + 1;
        allow delete: if isOwner(userId) &&
                        getAfter(/databases/$(database)/documents/groups/$(groupId)).data.membersCount == 
                        get(/databases/$(database)/documents/groups/$(groupId)).data.membersCount - 1;
      }
    }
  }
}
